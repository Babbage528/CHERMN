<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<StackPane prefHeight="720.0" prefWidth="1280.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.chermn.controller.QuizBeginController">

    <padding>
        <Insets bottom="50.0" left="100.0" right="50.0" top="200.0" />
    </padding>

    <children>
        <VBox alignment="TOP_CENTER">
            <children>
                <Label style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" text="Level 1!" />
                <Label style="-fx-font-size: 18px; -fx-font-fill: #666666; -fx-text-fill: #3E7C2B;" text="Difficulty: Easy" />
                <Label style="-fx-font-size: 18px; -fx-text-fill: #666666; -fx-text-fill: #3E7C2B;" text="Category: Animals" />
            </children>
        </VBox>

        <VBox alignment="CENTER" maxHeight="450.0" maxWidth="420.0" spacing="25.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <HBox spacing="10.0">
                            <Button fx:id="returnToHomepageButton" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="50.0"
                                    style="-fx-background-color: #6DBE45; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="Return To Farm" onAction="#returnToHomepageButtonClick"/>
                            <Button fx:id="beginQuizButton" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="50.0"
                                    style="-fx-background-color: #6DBE45; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand;" text="Begin Quiz    " onAction="#beginQuizButtonClick"/>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</StackPane>