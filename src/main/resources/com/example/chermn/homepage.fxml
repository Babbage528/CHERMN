<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="20.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.chermn.controller.MainController">
  <padding>
    <Insets bottom="20.0" left="20.0" right="20.0" top="20.0"/>
  </padding>

  <Label text="User Management Dashboard (Testing Mode)" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>

  <HBox VBox.vgrow="ALWAYS" spacing="20.0">
    <VBox spacing="10.0">
      <ListView fx:id="userListView" prefWidth="250" VBox.vgrow="ALWAYS" />
      <Button text="Add New User" onAction="#onAdd" maxWidth="Infinity" style="-fx-background-color: #76C043; -fx-text-fill: white;"/>
    </VBox>

    <VBox spacing="15.0" prefWidth="450" style="-fx-background-color: #ffffff; -fx-padding: 20; -fx-background-radius: 10;">
      <Label text="User Details Editor" style="-fx-font-weight: bold;" />
      <GridPane hgap="10.0" vgap="10.0" >
        <columnConstraints>
          <ColumnConstraints minWidth="100" />
          <ColumnConstraints hgrow="ALWAYS"/>
        </columnConstraints>

        <Label text="First Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="firstNameField" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label text="Last Name:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <TextField fx:id="lastNameField" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <TextField fx:id="usernameField" GridPane.columnIndex="1" GridPane.rowIndex="2" editable="false" style="-fx-background-color: #eeeeee;"/>

        <Label text="School:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="schoolField" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <PasswordField fx:id="passwordField" GridPane.columnIndex="1" GridPane.rowIndex="4" />
      </GridPane>

      <HBox spacing="10.0" alignment="CENTER">
        <Button text="Save Changes" onAction="#onEditConfirm" prefWidth="120" style="-fx-background-color: #2196F3; -fx-text-fill: white;"/>
        <Button text="Delete User" onAction="#onDelete" prefWidth="120" style="-fx-background-color: #f44336; -fx-text-fill: white;"/>
        <Button text="Logout" onAction="#handleLogout" prefWidth="100" />
      </HBox>
    </VBox>
  </HBox>
</VBox>