<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.chermn.controller.HomepageController">
    <children>
        <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true">
            <image>
                <Image url="@assets/images/Background.png" />
            </image>
        </ImageView>

        <GridPane prefHeight="720.0" prefWidth="1280.0">
            <columnConstraints>
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="100.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="600.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="250.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="250.0" />
                <ColumnConstraints hgrow="SOMETIMES" maxWidth="-Infinity" minWidth="10.0" prefWidth="220.0" />
            </columnConstraints>

            <rowConstraints>
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="350.0" vgrow="SOMETIMES" />
                <RowConstraints maxHeight="-Infinity" minHeight="10.0" prefHeight="150.0" vgrow="SOMETIMES" />
            </rowConstraints>

            <children>
                <!-- Animal Image -->
                <ImageView fx:id="animalImageView" fitHeight="100.0" fitWidth="100.0" pickOnBounds="true"
                           preserveRatio="true" GridPane.columnIndex="1" GridPane.rowIndex="3">
                    <GridPane.margin> <Insets bottom="35.0" left="250.0" /> </GridPane.margin>
                </ImageView>

                <!-- Animal Button - FIXED CURSOR -->
                <Button fx:id="animalButton"
                        accessibleText="Open animal quiz"
                        onAction="#animalButtonClick"
                        prefHeight="100.0" prefWidth="100.0"
                        style="-fx-background-color: transparent; -fx-cursor: hand;"
                        GridPane.columnIndex="1" GridPane.rowIndex="3"
                        onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak">
                    <GridPane.margin>
                        <Insets bottom="35.0" left="250.0" />
                    </GridPane.margin>
                </Button>

                <!-- Vehicle Image - FIXED SINTAKS (Hapus </Button> nyasar) -->
                <ImageView fx:id="vehicleImageView" pickOnBounds="true" preserveRatio="true"
                           GridPane.columnIndex="3" GridPane.rowIndex="3">
                    <GridPane.margin>
                        <Insets bottom="200.0" />
                    </GridPane.margin>
                </ImageView>

                <!-- Settings Icon -->
                <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Image url="@assets/images/Settings.png" />
                    <GridPane.margin>
                        <Insets left="5.0" />
                    </GridPane.margin>
                </ImageView>

                <!-- Settings Button -->
                <Button fx:id="settingsButton" accessibleText="Open settings"
                        onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                        mnemonicParsing="false" onAction="#settingsButtonClick"
                        prefHeight="60.0" prefWidth="60.0" style="-fx-background-color: transparent; -fx-cursor: hand;"
                        GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <GridPane.margin>
                        <Insets left="5.0" />
                    </GridPane.margin>
                </Button>

                <!-- Farm House Image -->
                <ImageView fitHeight="220.0" fitWidth="220.0" pickOnBounds="true" preserveRatio="true"
                           GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <image>
                        <Image url="@assets/images/farmHouse.png" />
                    </image>
                    <GridPane.margin>
                        <Insets bottom="200.0" />
                    </GridPane.margin>
                </ImageView>

                <!-- Farm House Button -->
                <Button fx:id="farmHouseButton" accessibleText="Go to farmhouse" minHeight="-Infinity" minWidth="-Infinity"
                        mnemonicParsing="false" onAction="#farmHouseButtonClick"
                        onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                        prefHeight="200.0" prefWidth="222.0" style="-fx-background-color: transparent; -fx-cursor: hand;" GridPane.columnIndex="2" GridPane.rowIndex="2">
                    <GridPane.margin>
                        <Insets bottom="200.0" />
                    </GridPane.margin>
                </Button>

                <!-- Corn Images (Nature) -->
                <ImageView fx:id="natureImageView1" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <GridPane.margin> <Insets bottom="120.0" left="-35.0" /> </GridPane.margin>
                </ImageView>

                <ImageView fx:id="natureImageView2" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <GridPane.margin> <Insets bottom="85.0" left="-5.0" /> </GridPane.margin>
                </ImageView>

                <ImageView fx:id="natureImageView3" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <GridPane.margin> <Insets bottom="55.0" left="30.0" /> </GridPane.margin>
                </ImageView>

                <ImageView fx:id="natureImageView4" fitHeight="100" fitWidth="100" pickOnBounds="true" preserveRatio="true" GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <GridPane.margin> <Insets bottom="25.0" left="70.0" /> </GridPane.margin>
                </ImageView>

                <!-- Corn Button -->
                <Button fx:id="cornButton"  accessibleText="open nature quiz"
                        onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                        minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#cornButtonClick"
                        prefHeight="130.0" prefWidth="160.0" style="-fx-background-color: transparent; -fx-cursor: hand;"
                        GridPane.columnIndex="4" GridPane.rowIndex="2">
                    <GridPane.margin>
                        <Insets bottom="50.0" left="-25.0" />
                    </GridPane.margin>
                </Button>

                <!-- Profile Image -->
                <ImageView fitHeight="60" fitWidth="60" pickOnBounds="true" preserveRatio="true"
                           GridPane.columnIndex="4" GridPane.rowIndex="0">
                    <image>
                        <Image url="@assets/images/account_circle.png" />
                    </image>
                    <GridPane.margin>
                        <Insets left="100.0" />
                    </GridPane.margin>
                </ImageView>

                <!-- Profile Button -->
                <Button fx:id="profileButton" accessibleText="open profile"
                        onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                        minHeight="-Infinity" minWidth="-Infinity" mnemonicParsing="false" onAction="#profileButtonClick"
                        prefHeight="60" prefWidth="60" style="-fx-background-color: transparent; -fx-cursor: hand;" GridPane.columnIndex="4"
                        GridPane.rowIndex="0">
                    <GridPane.margin>
                        <Insets left="100.0" />
                    </GridPane.margin>
                </Button>
            </children>
        </GridPane>
    </children>
</StackPane>