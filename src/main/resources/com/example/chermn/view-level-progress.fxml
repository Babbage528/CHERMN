<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane
        prefHeight="400.0" prefWidth="600.0"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.chermn.controller.ViewLevelProgressController">


    <!-- Creates a grid pane to store the user's current level information -->
    <GridPane hgap="20.0" layoutX="273.0" layoutY="15.0" prefHeight="490.0" prefWidth="605.0" AnchorPane.leftAnchor="-125.0">
    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
    </rowConstraints>


        <children>
            <Label text="Level Progress" GridPane.columnIndex="1">
                <font>
                    <Font name="System Bold Italic" size="24.0" />
                </font>
                <GridPane.margin>
                    <Insets left="-80.0" />
                </GridPane.margin>
            </Label>


            <Label layoutX="313.0" layoutY="45.0"
                   text="View my level progress"
                   GridPane.columnIndex="1">
                <font>
                    <Font name="System Bold Italic" size="14.0" />
                </font>
                <GridPane.margin>
                    <Insets left="-100.0" top="70.0" />
                </GridPane.margin>
            </Label>


            <Label text="Animal Category:"
                   GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold Italic" size="16.0" />
                </font>
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </Label>


            <Label
                    layoutX="10.0" layoutY="145.0"
                    text="Vehicle Category:"
                    GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold Italic" size="16.0" />
                </font>
                <GridPane.margin>
                    <Insets top="50.0" />
                </GridPane.margin>
            </Label>


            <Label
                    layoutX="10.0" layoutY="145.0"
                    text="Plant Category:"
                    GridPane.halignment="RIGHT" GridPane.rowIndex="2">
                <font>
                    <Font name="System Bold Italic" size="16.0" />
                </font>
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </Label>


            <!-- Labels to display the current user's level across the different categories-->
            <Label fx:id="natureLevel"
                   GridPane.columnIndex="1" GridPane.rowIndex="2">
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </Label>

            <Label fx:id="vehicleLevel"
                   GridPane.columnIndex="1" GridPane.rowIndex="1">
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </Label>

            <Label fx:id="animalLevel"
                   GridPane.columnIndex="1" GridPane.rowIndex="1">
                <GridPane.margin>
                    <Insets top="50.0" />
                </GridPane.margin>
            </Label>

        </children>

    </GridPane>

</AnchorPane>
