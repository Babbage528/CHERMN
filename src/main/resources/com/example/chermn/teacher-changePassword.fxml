<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<GridPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.chermn.controller.ChangeTeacherPasswordController"
            prefHeight="400.0" prefWidth="600.0">



    <!-- Creates a grid pane to store the user's password reset buttons -->
    <GridPane hgap="20.0"
              layoutX="273.0" layoutY="15.0"
              prefHeight="490.0" prefWidth="605.0"
              AnchorPane.leftAnchor="-125.0">

        <columnConstraints>
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
            <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>


        <children>
            <Label text="Change Password"
                   GridPane.columnIndex="1">
                <font>
                    <Font name="System Bold Italic" size="24.0" />
                </font>
                <GridPane.margin>
                    <Insets left="-80.0" />
                </GridPane.margin></Label>


            <Label text="Please enter new password:"
                   GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold Italic" size="16.0" />
                </font>
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </Label>


            <Label layoutX="10.0" layoutY="145.0"
                   text="Please re-enter password:"
                   GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold Italic" size="16.0" />
                </font>
                <GridPane.margin>
                    <Insets top="50.0" />
                </GridPane.margin>
            </Label>





            <!-- Password fields to allow user to update their password-->
            <PasswordField fx:id="newPasswordField"
                           GridPane.columnIndex="1" GridPane.rowIndex="1">
                <GridPane.margin>
                    <Insets bottom="40.0" />
                </GridPane.margin>
            </PasswordField>

            <PasswordField fx:id="reconfirmPasswordField"
                           GridPane.columnIndex="1" GridPane.rowIndex="1">
                <GridPane.margin>
                    <Insets top="50.0" />
                </GridPane.margin>
            </PasswordField>




            <!-- Creates an update button allowing the user to update their details -->
            <Button fx:id="updatePasswordButton"
                    layoutX="522.0" layoutY="338.0"
                    mnemonicParsing="false"
                    onAction="#updatePasswordButtonClick"
                    prefHeight="102.0" prefWidth="228.0"
                    style="-fx-background-color: #F7FAE9;"
                    text="Update Password"
                    GridPane.columnIndex="1" GridPane.rowIndex="4">
                <font>
                    <Font name="System Bold Italic" size="18.0" />
                </font>
                <GridPane.margin>
                    <Insets left="-80.0" />
                </GridPane.margin>
            </Button>

        </children>


    </GridPane>

</GridPane>
