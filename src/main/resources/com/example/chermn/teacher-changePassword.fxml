<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.Cursor?>

<GridPane xmlns="http://javafx.com/javafx"
          xmlns:fx="http://javafx.com/fxml"
          fx:controller="com.example.chermn.controller.ChangeTeacherPasswordController"
          prefHeight="400.0" prefWidth="600.0"
          hgap="20" vgap="20">

    <columnConstraints>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="150"/>
        <ColumnConstraints hgrow="SOMETIMES" minWidth="10" prefWidth="300"/>
    </columnConstraints>

    <rowConstraints>
        <RowConstraints minHeight="30" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="30" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="30" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="30" vgrow="SOMETIMES"/>
        <RowConstraints minHeight="30" vgrow="SOMETIMES"/>
    </rowConstraints>

    <!-- Title -->
    <Label text="Change Password"
           accessibleText="Change Password"
           onMouseEntered="#speakAccessibleText"
           onMouseExited="#cancelSpeak"
           GridPane.columnIndex="1">
        <font>
            <Font name="System Bold Italic" size="24"/>
        </font>
        <GridPane.margin>
            <Insets left="-80"/>
        </GridPane.margin>
    </Label>

    <!-- New Password Label -->
    <Label text="Please enter new password:"
           accessibleText="Please enter new password"
           onMouseEntered="#speakAccessibleText"
           onMouseExited="#cancelSpeak"
           GridPane.halignment="RIGHT"
           GridPane.rowIndex="1">
        <font>
            <Font name="System Bold Italic" size="16"/>
        </font>
        <GridPane.margin>
            <Insets bottom="20"/>
        </GridPane.margin>
    </Label>

    <!-- New Password Field -->
    <PasswordField fx:id="newPasswordField"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="1">
        <GridPane.margin>
            <Insets bottom="20"/>
        </GridPane.margin>
    </PasswordField>

    <!-- Re-enter Password Label -->
    <Label text="Please re-enter password:"
           accessibleText="Please re-enter password"
           onMouseEntered="#speakAccessibleText"
           onMouseExited="#cancelSpeak"
           GridPane.halignment="RIGHT"
           GridPane.rowIndex="2">
        <font>
            <Font name="System Bold Italic" size="16"/>
        </font>
        <GridPane.margin>
            <Insets top="10"/>
        </GridPane.margin>
    </Label>

    <!-- Re-enter Password Field -->
    <PasswordField fx:id="reconfirmPasswordField"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="2">
        <GridPane.margin>
            <Insets top="10"/>
        </GridPane.margin>
    </PasswordField>

    <!-- Update Button -->
    <Button fx:id="updatePasswordButton"
            text="Update Password"
            accessibleText="update password"
            onMouseEntered="#speakAccessibleText"
            onMouseExited="#cancelSpeak"
            onAction="#updatePasswordButtonClick"
            prefHeight="60" prefWidth="200"
            GridPane.columnIndex="1"
            GridPane.rowIndex="4"
            style="-fx-background-color: #F7FAE9;">
        <font>
            <Font name="System Bold Italic" size="18"/>
        </font>
        <GridPane.margin>
            <Insets left="-80"/>
        </GridPane.margin>
        <cursor><Cursor fx:constant="HAND"/></cursor>
    </Button>

</GridPane>