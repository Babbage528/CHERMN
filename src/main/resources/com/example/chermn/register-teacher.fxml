<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.Cursor?>

<StackPane prefHeight="720.0" prefWidth="1280.0"
           style="-fx-background-color: #E8F5E9;"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.TeacherRegisterController">

    <!-- Background -->
    <ImageView fitHeight="720.0" fitWidth="1280.0" preserveRatio="false">
        <image>
            <Image url="@assets/images/bg_general.png"/>
        </image>
    </ImageView>

    <children>
        <AnchorPane>
            <children>

                <!-- Back Button -->
                <Button onAction="#handleBack"
                        layoutX="40.0" layoutY="40.0"
                        prefHeight="45.0" prefWidth="45.0"
                        style="-fx-background-color: #76C043; -fx-background-radius: 50;">
                    <graphic>
                        <Label text="‹"
                               accessibleText="back"
                               onMouseEntered="#speakAccessibleText"
                               onMouseExited="#cancelSpeak"
                               style="-fx-text-fill: white; -fx-font-size: 28px;
                                      -fx-font-weight: bold; -fx-padding: 0 0 5 0;" />
                    </graphic>
                    <cursor><Cursor fx:constant="HAND"/></cursor>
                    <effect>
                        <DropShadow color="#00000033" radius="5" offsetY="2"/>
                    </effect>
                </Button>

                <!-- Step Label -->
                <Label layoutX="100.0" layoutY="90.0"
                       text="Step 2 of 2"
                       accessibleText="Step 2 of 2"
                       onMouseEntered="#speakAccessibleText"
                       onMouseExited="#cancelSpeak"
                       style="-fx-font-size: 18px; -fx-text-fill: #666666; -fx-font-weight: bold;" />

                <!-- Form Container -->
                <VBox layoutX="90.0" layoutY="120.0"
                      prefWidth="400.0"
                      spacing="20.0"
                      style="-fx-background-color: white; -fx-background-radius: 25;
                             -fx-padding: 30;
                             -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">

                    <children>

                        <!-- First Name -->
                        <VBox spacing="5.0">
                            <Label text="First Name*"
                                   accessibleText="first name"
                                   onMouseEntered="#speakAccessibleText"
                                   onMouseExited="#cancelSpeak"
                                   style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="firstNameField"
                                       prefHeight="45.0"
                                       promptText="First Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <!-- Last Name -->
                        <VBox spacing="5.0">
                            <Label text="Last Name*"
                                   accessibleText="last name"
                                   onMouseEntered="#speakAccessibleText"
                                   onMouseExited="#cancelSpeak"
                                   style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="lastNameField"
                                       prefHeight="45.0"
                                       promptText="Last Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <!-- School Name -->
                        <VBox spacing="5.0">
                            <Label text="School Name*"
                                   accessibleText="School name"
                                   onMouseEntered="#speakAccessibleText"
                                   onMouseExited="#cancelSpeak"
                                   style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="schoolNameField"
                                       prefHeight="45.0"
                                       promptText="School Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <!-- Email -->
                        <VBox spacing="5.0">
                            <Label text="Email*"
                                   accessibleText="Email"
                                   onMouseEntered="#speakAccessibleText"
                                   onMouseExited="#cancelSpeak"
                                   style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="unameField"
                                       prefHeight="45.0"
                                       promptText="Email"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <!-- Password -->
                        <VBox spacing="5.0">
                            <Label text="Password*"
                                   accessibleText="Password"
                                   onMouseEntered="#speakAccessibleText"
                                   onMouseExited="#cancelSpeak"
                                   style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <PasswordField fx:id="passwordField"
                                           prefHeight="45.0"
                                           promptText="••••••••"
                                           style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <!-- Next Button -->
                        <Button fx:id="nextButton"
                                onAction="#handleRegisterSubmit"
                                prefHeight="50.0"
                                maxWidth="Infinity"
                                text="Next"
                                accessibleText="next"
                                onMouseEntered="#speakAccessibleText"
                                onMouseExited="#cancelSpeak"
                                style="-fx-background-color: #76C043; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 16px;
                                       -fx-background-radius: 12;">
                            <cursor><Cursor fx:constant="HAND"/></cursor>
                            <VBox.margin>
                                <Insets top="10.0"/>
                            </VBox.margin>
                        </Button>

                    </children>
                </VBox>

            </children>
        </AnchorPane>
    </children>

</StackPane>