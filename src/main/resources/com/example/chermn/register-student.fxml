<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #E8F5E9;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.chermn.controller.StudentRegisterController">
    <ImageView fitHeight="720.0" fitWidth="1280.0" preserveRatio="false">
        <Image url="@assets/images/bg_general.png"/>
    </ImageView>
    <children>
        <AnchorPane>
            <children>
                <Button onAction="#handleBack" layoutX="40.0" layoutY="40.0" prefHeight="45.0" prefWidth="45.0"
                        style="-fx-background-color: #76C043; -fx-background-radius: 50; -fx-cursor: hand;">
                    <graphic>
                        <Label text="‹" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;" />
                    </graphic>
                    <effect>
                        <DropShadow color="#00000033" radius="5" offsetY="2" />
                    </effect>
                </Button>
                <Label layoutX="100.0" layoutY="90.0" text="Step 2 of 2" style="-fx-font-size: 18px; -fx-text-fill: #666666; -fx-font-weight: bold;" />

                <VBox layoutX="90.0" layoutY="120.0" prefWidth="400.0" spacing="20.0"
                      style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <children>

                        <VBox spacing="5.0">
                            <Label text="First Name" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="firstNameField" prefHeight="45.0" promptText="First Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Last Name" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="lastNameField" prefHeight="45.0" promptText="Last Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="School Name" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="schoolNameField" prefHeight="45.0" promptText="School Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

<!--                        <VBox spacing="5.0">-->
<!--                            <Label text="Grade" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />-->
<!--                            <ComboBox fx:id="gradeComboBox" prefHeight="45.0" prefWidth="Infinity" promptText="Grade"-->
<!--                                      style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;">-->
<!--                                <items>-->
<!--                                    <FXCollections fx:factory="observableArrayList">-->
<!--                                        <String fx:value="Grade 1" />-->
<!--                                        <String fx:value="Grade 2" />-->
<!--                                        <String fx:value="Grade 3" />-->
<!--                                        <String fx:value="Grade 4" />-->
<!--                                        <String fx:value="Grade 5" />-->
<!--                                        <String fx:value="Grade 6" />-->
<!--                                    </FXCollections>-->
<!--                                </items>-->
<!--                            </ComboBox>-->
<!--                        </VBox>-->

                        <VBox spacing="5.0">
                            <Label text="Email" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="unameField" prefHeight="45.0" promptText="Email"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>
                        <VBox spacing="5.0">
                            <Label text="Password" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <PasswordField fx:id="passwordField" prefHeight="45.0" promptText="••••••••"
                                           style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <Button fx:id="nextButton" onAction="#handleRegisterSubmit" prefHeight="50.0" maxWidth="Infinity" text="Next"
                                style="-fx-background-color: #76C043; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 12; -fx-cursor: hand;">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>