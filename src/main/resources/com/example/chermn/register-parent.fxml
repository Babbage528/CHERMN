<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<StackPane prefHeight="720.0" prefWidth="1280.0" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.chermn.controller.ParentRegisterController">
    <children>
        <ImageView fitHeight="720.0" fitWidth="1280.0" preserveRatio="false">
            <Image url="@assets/images/bg_general.png"/>
        </ImageView>

        <AnchorPane>
            <children>
                <Button onAction="#handleBack" layoutX="40.0" layoutY="40.0" prefHeight="45.0" prefWidth="45.0"
                        style="-fx-background-color: #76C043; -fx-background-radius: 50; -fx-cursor: hand;">
                    <graphic>
                        <Label text="‹" style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;" />
                    </graphic>
                    <effect>
                        <DropShadow color="#00000033" radius="5" offsetY="2" />
                    </effect>
                </Button>
                <Label layoutX="100.0" layoutY="40.0" text="Step 2 of 2"
                       style="-fx-font-size: 18px; -fx-text-fill: #666666; -fx-font-weight: bold;" />

                <VBox layoutX="90.0" layoutY="75.0" prefWidth="400.0" spacing="10.0"
                      style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 25;">
                    <effect>
                        <DropShadow color="#0000001a" radius="15" offsetY="5" />
                    </effect>
                    <children>

                        <HBox spacing="10.0">
                            <children>
                                <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                    <Label text="First Name" style="-fx-text-fill: #999999; -fx-font-size: 12px;" />
                                    <TextField fx:id="firstNameField" prefHeight="35.0" promptText="First Name"
                                               style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                                </VBox>
                                <VBox HBox.hgrow="ALWAYS" spacing="2.0">
                                    <Label text="Last Name" style="-fx-text-fill: #999999; -fx-font-size: 12px;" />
                                    <TextField fx:id="lastNameField" prefHeight="35.0" promptText="Last Name"
                                               style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                                </VBox>
                            </children>
                        </HBox>

                        <VBox spacing="4.0">
                            <Label text="Email" style="-fx-text-fill: #999999; -fx-font-size: 13px;" />
                            <TextField fx:id="unameField" prefHeight="40.0" promptText="example@mail.com"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label text="Password" style="-fx-text-fill: #999999; -fx-font-size: 13px;" />
                            <PasswordField fx:id="passwordField" prefHeight="40.0" promptText="••••••••"
                                           style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <Separator style="-fx-opacity: 0.5;">
                            <VBox.margin><Insets top="5.0" bottom="5.0"/></VBox.margin>
                        </Separator>

                        <VBox spacing="4.0">
                            <Label text="Relationship to Student" style="-fx-text-fill: #999999; -fx-font-size: 13px;" />
                            <ComboBox fx:id="relationshipComboBox" prefHeight="40.0" prefWidth="Infinity"
                                      style="-fx-background-color: #ECF5E9; -fx-background-radius: 10;">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Parent" />
                                        <String fx:value="Guardian" />
                                        <String fx:value="Sibling" />
                                    </FXCollections>
                                </items>
                                <value><String fx:value="Parent" /></value>
                            </ComboBox>
                        </VBox>

                        <VBox spacing="4.0">
                            <Label text="Student Name" style="-fx-text-fill: #999999; -fx-font-size: 13px;" />
                            <TextField fx:id="studentNameField" prefHeight="40.0" promptText="Full Student Name"
                                       style="-fx-background-color: #ECF5E9; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="4.0">
                            <Label text="School Name" style="-fx-text-fill: #999999; -fx-font-size: 13px;" />
                            <TextField fx:id="schoolNameField" prefHeight="40.0" promptText="School Name"
                                       style="-fx-background-color: #ECF5E9; -fx-background-radius: 10;" />
                        </VBox>

                        <Button fx:id="nextButton" onAction="#handleRegisterSubmit" prefHeight="50.0" maxWidth="Infinity" text="Next"
                                style="-fx-background-color: #76C043; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18px; -fx-background-radius: 12; -fx-cursor: hand;">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>