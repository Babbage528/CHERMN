<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: #E8F5E9;" xmlns:fx="http://javafx.com/fxml" fx:controller="com.example.chermn.controller.StudentRegisterController">
    <children>
        <ImageView fitHeight="720.0" fitWidth="1280.0" pickOnBounds="true">
            <image>
                <Image url="@assets.images/bg-1.png" />
            </image>
        </ImageView>

        <AnchorPane>
            <children>
                <Label layoutX="100.0" layoutY="140.0" text="Step 2 of 2" style="-fx-font-size: 18px; -fx-text-fill: #666666; -fx-font-weight: bold;" />

                <VBox layoutX="90.0" layoutY="180.0" prefWidth="400.0" spacing="20.0"
                      style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <children>

                        <VBox spacing="5.0">
                            <Label text="Full Name" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="fullNameField" prefHeight="45.0" promptText="Full Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="School Name" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="schoolNameField" prefHeight="45.0" promptText="School Name"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Grade" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <ComboBox fx:id="gradeComboBox" prefHeight="45.0" prefWidth="Infinity" promptText="Grade"
                                      style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;">
                                <items>
                                    <FXCollections fx:factory="observableArrayList">
                                        <String fx:value="Grade 1" />
                                        <String fx:value="Grade 2" />
                                        <String fx:value="Grade 3" />
                                        <String fx:value="Grade 4" />
                                        <String fx:value="Grade 5" />
                                        <String fx:value="Grade 6" />
                                    </FXCollections>
                                </items>
                            </ComboBox>
                        </VBox>

                        <VBox spacing="5.0">
                            <Label text="Email" style="-fx-text-fill: #999999; -fx-font-size: 14px;" />
                            <TextField fx:id="emailField" prefHeight="45.0" promptText="Email"
                                       style="-fx-background-color: #F0F7EE; -fx-background-radius: 10;" />
                        </VBox>

                        <Button fx:id="nextButton" onAction="#handleRegisterSubmit" prefHeight="50.0" maxWidth="Infinity" text="Next"
                                style="-fx-background-color: #76C043; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 16px; -fx-background-radius: 12; -fx-cursor: hand;">
                            <VBox.margin>
                                <Insets top="10.0" />
                            </VBox.margin>
                        </Button>

                    </children>
                </VBox>
            </children>
        </AnchorPane>
    </children>
</StackPane>