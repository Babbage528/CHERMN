<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.image.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.QuizResultsController">
    <ImageView fitHeight="1000" fitWidth="2010" pickOnBounds="true" preserveRatio="true" opacity="0.4">
        <Image url="@assets/images/quiz-questions-background.png"/>
    </ImageView>
    <Rectangle width="1160" height="600" fill="#98CB68" arcHeight="30" arcWidth="30"/>
    <ImageView fitHeight="100" fitWidth="200" pickOnBounds="true" preserveRatio="true" translateX="400" translateY="250">
        <Image url="@assets/images/1 Chicken.png" />
    </ImageView>

    <children>
        <StackPane>
            <padding>
                <Insets bottom="50.0" top="200.0" />
            </padding>
            <VBox alignment="TOP_CENTER">
                <children>
                    <Label fx:id="congratsLabel" style="-fx-font-size: 56px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" />
                    <Label fx:id="resultsLabel" style="-fx-font-size: 28px; -fx-font-fill: #666666; -fx-text-fill: #3E7C2B;" />
                </children>
            </VBox>

            <VBox alignment="CENTER" maxHeight="450.0" maxWidth="420.0" spacing="25.0">
                <children>
                    <VBox alignment="CENTER" spacing="10.0">
                        <children>
                            <HBox spacing="10.0">
                                <Button fx:id="returnToHomepageButton" HBox.hgrow="ALWAYS" prefWidth="500.0" prefHeight="75.0"
                                        style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-font-size: 20px; -fx-background-radius: 12; -fx-cursor: hand;" text="Return to farm" onAction="#returnToHomepageButtonClick"/>
                            </HBox>
                        </children>
                    </VBox>
                </children>
            </VBox>
        </StackPane>
    </children>
</StackPane>