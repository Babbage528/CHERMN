<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>



<StackPane prefHeight="720.0" prefWidth="1280.0"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.QuizQuestionsController">
    <ImageView fitHeight="1000" fitWidth="2010" pickOnBounds="true" preserveRatio="true" opacity="0.4">
        <Image url="@assets/images/quiz-questions-background.png"/>
    </ImageView>
    <children>
        <StackPane>
            <padding>
                <Insets bottom="50.0" top="50.0" />
            </padding>
            <VBox alignment="CENTER">
                <children>
                <VBox alignment="CENTER" maxHeight="400.0" maxWidth="1000" spacing="25.0">
                    <children>
                    <Button fx:id="questionbutton" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="100.0"
                            style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" text="Q1. What Season is Best to Grow Strawberries?" />
                    <VBox alignment="CENTER" spacing="150.0">
                        <children>
                            <HBox spacing="10.0">
                                <Button fx:id="option1" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="100.0"
                                        style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" text="a) Summer" />
                                <Button fx:id="option2" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="100.0"
                                        style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" text="b) Winter"/>
                            </HBox>
                        </children>
                    </VBox>
                        <VBox alignment="CENTER" spacing="100.0">
                            <children>
                                <HBox spacing="10.0">
                                    <Button fx:id="option3" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="100.0"
                                            style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" text="c) Autumn" />
                                    <Button fx:id="option4" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="100.0"
                                            style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" text="d) Spring"/>
                                </HBox>
                            </children>
                        </VBox>
                </children>
                </VBox>
                </children>
            </VBox>
        </StackPane>
    </children>
</StackPane>