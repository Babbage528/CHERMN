<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>



<StackPane prefHeight="720.0" prefWidth="1280.0"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.QuizQuestionsController">

    <!-- setting background image with slight opacity -->
    <ImageView fitHeight="1000" fitWidth="2010" pickOnBounds="true" preserveRatio="true" opacity="0.4">
        <Image url="@assets/images/quiz-questions-background.png"/>
    </ImageView>

    <children>
        <StackPane>
            <padding>
                <Insets bottom="50.0" top="40.0" />
            </padding>

            <!-- blank label to be changed by controller -->
            <VBox fx:id="container">
                <Label fx:id="explanation" text=" " style="-fx-text-fill: #3E7C2B" alignment="CENTER"  prefWidth="2000" prefHeight="70.0"/>
            </VBox>
            <VBox alignment="CENTER">
                <children>
                <VBox alignment="CENTER" maxHeight="400.0" maxWidth="1000" spacing="25.0">
                    <children>

                        <Label fx:id="new" text=" " prefWidth="200" prefHeight="50.0"/>

                        <!-- where question is displayed with variable size for larger text inputs -->
                    <Button fx:id="questionbutton" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="160.0"
                            style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px; -fx-wrap-text:true;" text=" "  />
                    <VBox alignment="CENTER" spacing="150.0">
                        <children>
                            <!-- first row of buttons -->
                            <HBox spacing="10.0">
                                <!-- first button with light green on action -> AnswerSubmitted-->
                                <Button fx:id="option1" HBox.hgrow="ALWAYS" maxWidth="500"  minWidth="500" prefHeight="100.0"
                                        style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" onAction="#AnswerSubmitted" text=" " />

                                <!-- second button with dark green on action -> AnswerSubmitted-->
                                <Button fx:id="option2" HBox.hgrow="ALWAYS" maxWidth="500" minWidth="500"  prefHeight="100.0"
                                        style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" onAction="#AnswerSubmitted"  text=" "/>
                            </HBox>
                        </children>
                    </VBox>
                        <VBox alignment="CENTER" spacing="100.0">
                            <children>

                                <!-- second row of buttons -->
                                <HBox spacing="10.0">
                                    <!-- third button with dark green on action -> AnswerSubmitted-->
                                    <Button fx:id="option3" HBox.hgrow="ALWAYS" maxWidth="500"  minWidth="500" prefHeight="100.0"
                                            style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" onAction="#AnswerSubmitted" text=" " />

                                    <!-- fourth button with light green on action -> AnswerSubmitted-->
                                    <Button fx:id="option4" HBox.hgrow="ALWAYS" maxWidth="500"  minWidth="500" prefHeight="100.0"
                                            style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" onAction="#AnswerSubmitted" text=" "/>
                                </HBox>
                            </children>
                        </VBox>
                </children>
                </VBox>
                </children>
                <VBox alignment="CENTER" >
                    <Label fx:id="paragraph" text=" " prefWidth="200" prefHeight="50.0"/>
                    <HBox spacing="800.0">
                <Button fx:id="start" HBox.hgrow="ALWAYS" maxWidth="200" prefHeight="50.0"
                        style="-fx-background-color: transparent; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;"/>

                        <!-- next question button -->
                        <Button fx:id="Next" HBox.hgrow="ALWAYS" maxWidth="200" prefHeight="100.0"
                            disable="true" style="-fx-background-color: #ECFCE3; -fx-text-fill: #3E7C2B; -fx-font-weight: bold; -fx-background-radius: 12; -fx-cursor: hand; -fx-font-size: 20px;" onAction="#nextQuestion" text="Next"/>

                    </HBox>
                </VBox>
            </VBox>
        </StackPane>
    </children>
</StackPane>