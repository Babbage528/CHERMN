<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.*?>
<?import javafx.scene.Cursor?>

<StackPane prefHeight="720.0" prefWidth="1280.0"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.QuizQuestionsController">

    <!-- Background -->
    <ImageView fitHeight="1000" fitWidth="2010" pickOnBounds="true" preserveRatio="true" opacity="0.4">
        <image>
            <Image url="@assets/images/quiz-questions-background.png"/>
        </image>
    </ImageView>

    <children>
        <StackPane>
            <padding>
                <Insets bottom="50.0" top="40.0" />
            </padding>

            <!-- Explanation label container -->
            <VBox fx:id="container">
                <Label fx:id="explanation"
                       wrapText="true"
                       text=" "
                       alignment="CENTER"
                       prefWidth="2000"
                       prefHeight="70.0"
                       style="-fx-text-fill: #3E7C2B;" />
            </VBox>

            <VBox alignment="CENTER">
                <children>

                    <VBox alignment="CENTER" maxHeight="400.0" maxWidth="1000" spacing="25.0">
                        <children>

                            <Label fx:id="new" text=" " prefWidth="200" prefHeight="50.0"/>

                            <!-- Question button -->
                            <Button fx:id="questionbutton"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    prefHeight="160.0"
                                    text=" "
                                    style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B;
                                           -fx-font-weight: bold; -fx-background-radius: 12;
                                           -fx-font-size: 20px; -fx-wrap-text: true;">
                            </Button>

                            <!-- First row of answer buttons -->
                            <VBox alignment="CENTER" spacing="150.0">
                                <children>
                                    <HBox spacing="10.0">

                                        <!-- Option 1 -->
                                        <Button fx:id="option1"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="500"
                                                minWidth="500"
                                                prefHeight="100.0"
                                                text=" "
                                                onAction="#AnswerSubmitted"
                                                style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B;
                                                       -fx-font-weight: bold; -fx-background-radius: 12;
                                                       -fx-font-size: 20px;">
                                            <cursor><Cursor fx:constant="HAND"/></cursor>
                                        </Button>

                                        <!-- Option 2 -->
                                        <Button fx:id="option2"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="500"
                                                minWidth="500"
                                                prefHeight="100.0"
                                                text=" "
                                                onAction="#AnswerSubmitted"
                                                style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B;
                                                       -fx-font-weight: bold; -fx-background-radius: 12;
                                                       -fx-font-size: 20px;">
                                            <cursor><Cursor fx:constant="HAND"/></cursor>
                                        </Button>

                                    </HBox>
                                </children>
                            </VBox>

                            <!-- Second row of answer buttons -->
                            <VBox alignment="CENTER" spacing="100.0">
                                <children>
                                    <HBox spacing="10.0">

                                        <!-- Option 3 -->
                                        <Button fx:id="option3"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="500"
                                                minWidth="500"
                                                prefHeight="100.0"
                                                text=" "
                                                onAction="#AnswerSubmitted"
                                                style="-fx-background-color: #6DBE45; -fx-text-fill: #3E7C2B;
                                                       -fx-font-weight: bold; -fx-background-radius: 12;
                                                       -fx-font-size: 20px;">
                                            <cursor><Cursor fx:constant="HAND"/></cursor>
                                        </Button>

                                        <!-- Option 4 -->
                                        <Button fx:id="option4"
                                                HBox.hgrow="ALWAYS"
                                                maxWidth="500"
                                                minWidth="500"
                                                prefHeight="100.0"
                                                text=" "
                                                onAction="#AnswerSubmitted"
                                                style="-fx-background-color: #E7FF76; -fx-text-fill: #3E7C2B;
                                                       -fx-font-weight: bold; -fx-background-radius: 12;
                                                       -fx-font-size: 20px;">
                                            <cursor><Cursor fx:constant="HAND"/></cursor>
                                        </Button>

                                    </HBox>
                                </children>
                            </VBox>

                        </children>
                    </VBox>

                </children>

                <!-- Bottom navigation -->
                <VBox alignment="CENTER">
                    <children>

                        <Label fx:id="paragraph" text=" " prefWidth="200" prefHeight="50.0"/>

                        <HBox spacing="800.0">

                            <!-- Start button -->
                            <Button fx:id="start"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="200"
                                    prefHeight="50.0"
                                    style="-fx-background-color: transparent; -fx-text-fill: #3E7C2B;
                                           -fx-font-weight: bold; -fx-background-radius: 12;
                                           -fx-font-size: 20px;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>

                            <!-- Next question button -->
                            <Button fx:id="Next"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="200"
                                    prefHeight="100.0"
                                    disable="true"
                                    text="Next"
                                    accessibleText="Next"
                                    onAction="#nextQuestion"
                                    style="-fx-background-color: #ECFCE3; -fx-text-fill: #3E7C2B;
                                           -fx-font-weight: bold; -fx-background-radius: 12;
                                           -fx-font-size: 20px;">
                                <cursor><Cursor fx:constant="HAND"/></cursor>
                            </Button>

                        </HBox>

                    </children>
                </VBox>

            </VBox>

        </StackPane>
    </children>

</StackPane>