<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.Cursor?>

<StackPane alignment="TOP_LEFT" prefHeight="720.0" prefWidth="1280.0"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.OnBoardingController">

    <!-- Background -->
    <ImageView fitHeight="720.0" fitWidth="1280.0" preserveRatio="false">
        <image>
            <Image url="@assets/images/bg_general.png"/>
        </image>
    </ImageView>

    <VBox spacing="40.0">
        <padding>
            <Insets bottom="50.0" left="100.0" right="50.0" top="200.0" />
        </padding>

        <children>

            <!-- Welcome Text -->
            <VBox spacing="5.0"
                  accessibleText="Welcome to Farmer Fred's Trivia"
                  onMouseEntered="#speakAccessibleText"
                  onMouseExited="#cancelSpeak">

                <Label text="Welcome to"
                       style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" />

                <Label text="Farmer Fred's Trivia"
                       style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" />

                <Label text="Let's get started"
                       accessibleText="Let's get started"
                       onMouseEntered="#speakAccessibleText"
                       onMouseExited="#cancelSpeak"
                       style="-fx-font-size: 18px; -fx-text-fill: #666666;" />
            </VBox>

            <!-- Buttons -->
            <HBox spacing="10.0" maxWidth="420.0">

                <!-- Sign Up Button -->
                <Button fx:id="signUpButton"
                        text="Sign Up"
                        accessibleText="Sign up"
                        onMouseEntered="#speakAccessibleText"
                        onMouseExited="#cancelSpeak"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        prefHeight="50.0"
                        onAction="#signUpButtonClick"
                        style="-fx-background-color: #6DBE45; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-background-radius: 12;">
                    <cursor><Cursor fx:constant="HAND"/></cursor>
                </Button>

                <!-- Log In Button -->
                <Button fx:id="loginButton"
                        text="Log In"
                        accessibleText="log in"
                        onMouseEntered="#speakAccessibleText"
                        onMouseExited="#cancelSpeak"
                        HBox.hgrow="ALWAYS"
                        maxWidth="Infinity"
                        prefHeight="50.0"
                        onAction="#logInButtonClick"
                        style="-fx-background-color: #F7FAE9; -fx-stroke: #6DBE45; -fx-stroke-width: 1px;
                               -fx-text-fill: #6DBE45; -fx-font-weight: bold; -fx-background-radius: 12;">
                    <cursor><Cursor fx:constant="HAND"/></cursor>
                </Button>

            </HBox>

        </children>
    </VBox>

</StackPane>