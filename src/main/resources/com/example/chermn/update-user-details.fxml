<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<AnchorPane
        prefHeight="400.0" prefWidth="600.0"
        xmlns="http://javafx.com/javafx/17.0.12"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.chermn.controller.UpdateUserDetailsController">


    <children>
                <!-- Creates a grid pane to store the user's profile information -->
                <GridPane hgap="20.0"
                          layoutX="273.0" layoutY="15.0"
                          prefHeight="490.0" prefWidth="605.0"
                          AnchorPane.leftAnchor="-125.0">

                    <columnConstraints>
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                    </columnConstraints>

                    <rowConstraints>
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                    </rowConstraints>

                    <children>

                        <Label text="User Profile"
                               GridPane.columnIndex="1">
                            <font>
                                <Font name="System Bold Italic" size="24.0" />
                            </font>
                            <GridPane.margin>
                                <Insets left="-80.0" />
                            </GridPane.margin>
                        </Label>


                        <Label
                                layoutX="313.0" layoutY="45.0"
                                text="View your personal details"
                                GridPane.columnIndex="1">
                            <font>
                                <Font name="System Bold Italic" size="14.0" />
                            </font>
                            <GridPane.margin>
                                <Insets left="-100.0" top="70.0" />
                            </GridPane.margin>
                        </Label>


                        <Label text="First Name:"
                               GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                            <font>
                                <Font name="System Bold Italic" size="16.0" />
                            </font>
                            <GridPane.margin>
                                <Insets bottom="40.0" />
                            </GridPane.margin>
                        </Label>


                        <Label
                                layoutX="10.0" layoutY="145.0"
                                text="Last Name:"
                                GridPane.halignment="RIGHT" GridPane.rowIndex="1">
                            <font>
                                <Font name="System Bold Italic" size="16.0" />
                            </font>
                            <GridPane.margin>
                                <Insets left="200.0" top="50.0" />
                            </GridPane.margin>
                        </Label>


                        <Label
                                layoutX="10.0" layoutY="145.0"
                                text="Username:"
                                GridPane.halignment="RIGHT" GridPane.rowIndex="2">
                            <font>
                                <Font name="System Bold Italic" size="16.0" />
                            </font>
                            <GridPane.margin>
                                <Insets bottom="40.0" left="200.0" />
                            </GridPane.margin>
                        </Label>


                        <Label
                                layoutX="10.0" layoutY="243.0"
                                text="Email:"
                                GridPane.halignment="RIGHT" GridPane.rowIndex="2">
                            <font>
                                <Font name="System Bold Italic" size="16.0" />
                            </font>
                            <GridPane.margin>
                                <Insets left="200.0" top="50.0" />
                            </GridPane.margin>
                        </Label>


                        <Label
                                layoutX="10.0" layoutY="243.0"
                                text="School:"
                                GridPane.halignment="RIGHT" GridPane.rowIndex="3">
                            <font>
                                <Font name="System Bold Italic" size="16.0" />
                            </font>
                            <GridPane.margin>
                                <Insets bottom="40.0" />
                            </GridPane.margin>
                        </Label>


                        <!-- Creates an update button allowing the user to update their details -->
                        <Button fx:id="updateButton"
                                layoutX="522.0" layoutY="338.0"
                                mnemonicParsing="false"
                                onAction="#updateButtonClick"
                                prefHeight="50.0" prefWidth="140.0"
                                style="-fx-background-color: #F7FAE9;"
                                text="Update"
                                GridPane.columnIndex="1" GridPane.rowIndex="4">
                            <font>
                                <Font name="System Bold Italic" size="18.0" />
                            </font>
                            <GridPane.margin>
                                <Insets left="-80.0" />
                            </GridPane.margin>
                        </Button>

                        <!-- label to display the user's username as can't be changed -->
                        <Label fx:id="usernameLabel"
                               GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <GridPane.margin>
                                <Insets bottom="40.0" />
                            </GridPane.margin>
                        </Label>

                        <!-- Text fields for the user's personal data -->
                        <TextField fx:id="firstNameField"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <GridPane.margin>
                                <Insets bottom="40.0" />
                            </GridPane.margin>
                        </TextField>


                        <TextField fx:id="lastNameField"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1">
                            <GridPane.margin>
                                <Insets top="50.0" />
                            </GridPane.margin>
                        </TextField>

                        <TextField fx:id="emailField"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2">
                            <GridPane.margin>
                                <Insets top="50.0" />
                            </GridPane.margin>
                        </TextField>


                        <TextField fx:id="schoolField"
                                   GridPane.columnIndex="1" GridPane.rowIndex="3">
                            <GridPane.margin>
                                <Insets bottom="40.0" />
                            </GridPane.margin>
                        </TextField>

                    </children>

                </GridPane>

            </children>

</AnchorPane>
