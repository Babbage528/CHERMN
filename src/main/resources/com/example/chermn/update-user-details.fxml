<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.Cursor?>

<AnchorPane prefHeight="400.0" prefWidth="600.0"
            xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.chermn.controller.UpdateUserDetailsController">

    <children>

        <GridPane hgap="20" vgap="20"
                  layoutX="100" layoutY="20"
                  prefWidth="500">

            <!-- Column Setup -->
            <columnConstraints>
                <ColumnConstraints prefWidth="150" halignment="RIGHT"/>
                <ColumnConstraints prefWidth="300"/>
            </columnConstraints>

            <!-- Row Setup -->
            <rowConstraints>
                <RowConstraints minHeight="40"/>
                <RowConstraints minHeight="40"/>
                <RowConstraints minHeight="40"/>
                <RowConstraints minHeight="40"/>
                <RowConstraints minHeight="40"/>
            </rowConstraints>

            <!-- Title -->
            <Label text="User Profile"
                   accessibleText="User profile"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.columnIndex="1">
                <font>
                    <Font name="System Bold Italic" size="24"/>
                </font>
                <GridPane.margin>
                    <Insets left="-80"/>
                </GridPane.margin>
            </Label>

            <!-- Subtitle -->
            <Label text="View your personal details"
                   accessibleText="view your personal details"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="1">
                <font>
                    <Font name="System Bold Italic" size="14"/>
                </font>
                <GridPane.margin>
                    <Insets left="-80"/>
                </GridPane.margin>
            </Label>

            <!-- First Name -->
            <Label text="First Name*:"
                   accessibleText="first name"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.rowIndex="2">
                <font>
                    <Font name="System Bold Italic" size="16"/>
                </font>
            </Label>

            <TextField fx:id="firstNameField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="2"/>

            <!-- Last Name -->
            <Label text="Last Name*:"
                   accessibleText="last name"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.rowIndex="3">
                <font>
                    <Font name="System Bold Italic" size="16"/>
                </font>
            </Label>

            <TextField fx:id="lastNameField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="3"/>

            <!-- Username (read-only label) -->
            <Label text="Username*:"
                   accessibleText="username"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.rowIndex="4">
                <font>
                    <Font name="System Bold Italic" size="16"/>
                </font>
            </Label>

            <Label fx:id="usernameLabel"
                   GridPane.columnIndex="1"
                   GridPane.rowIndex="4"/>

            <!-- Email -->
            <Label text="Email*:"
                   accessibleText="email"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.rowIndex="5">
                <font>
                    <Font name="System Bold Italic" size="16"/>
                </font>
            </Label>

            <TextField fx:id="emailField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="5"/>

            <!-- School -->
            <Label text="School*:"
                   accessibleText="school"
                   onMouseEntered="#speakAccessibleText"
                   onMouseExited="#cancelSpeak"
                   GridPane.rowIndex="6">
                <font>
                    <Font name="System Bold Italic" size="16"/>
                </font>
            </Label>

            <TextField fx:id="schoolField"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="6"/>

            <!-- Update Button -->
            <Button fx:id="updateButton"
                    text="Update"
                    accessibleText="update my details"
                    onMouseEntered="#speakAccessibleText"
                    onMouseExited="#cancelSpeak"
                    onAction="#updateButtonClick"
                    prefWidth="140" prefHeight="50"
                    style="-fx-background-color: #F7FAE9;"
                    GridPane.columnIndex="1"
                    GridPane.rowIndex="7">
                <font>
                    <Font name="System Bold Italic" size="18"/>
                </font>
                <cursor><Cursor fx:constant="HAND"/></cursor>
                <GridPane.margin>
                    <Insets left="-80"/>
                </GridPane.margin>
            </Button>

        </GridPane>

    </children>

</AnchorPane>