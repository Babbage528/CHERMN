<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.effect.DropShadow?>

<StackPane prefHeight="720.0" prefWidth="1280.0" xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.example.chermn.controller.RoleSelectionController">

  <children>
    <!-- 1. Background Layer -->
    <ImageView pickOnBounds="true" preserveRatio="false" opacity="0.4"
               fitWidth="1280.0" fitHeight="720.0">
      <image>
        <Image url="@assets/images/bg_general.png" />
      </image>
    </ImageView>

    <!-- 2. Main Content Layer -->
    <VBox alignment="CENTER" spacing="40.0">
      <children>
        <VBox alignment="CENTER" spacing="5.0">
          <Label text="Who are you?" accessibleText="Who are you?"
                 onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                 style="-fx-font-size: 48px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" />
        </VBox>

        <VBox alignment="CENTER_LEFT" spacing="5.0">
          <padding>
            <Insets left="150.0" />
          </padding>
          <children>
            <Label text="Step 1 of 2" accessibleText="Step 1 of 2"
                   onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                   style="-fx-font-size: 16px; -fx-text-fill: #666666;" />
          </children>
        </VBox>

        <VBox alignment="CENTER" spacing="30.0" maxWidth="1000.0"
              style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 10);">
          <children>
            <HBox alignment="CENTER" spacing="25.0">
              <children>
                <VBox fx:id="studentCard" onMouseClicked="#selectStudent" accessibleText="I'm a student."
                      onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak" alignment="CENTER"
                      spacing="15.0" prefWidth="250.0" minWidth="250" maxWidth="250"
                      prefHeight="300" minHeight="300" maxHeight="300"
                      style="-fx-background-color: #D5E8D4; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                  <children>
                    <ImageView fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                      <image>
                        <Image url="@assets/images/student_chick.png" />
                      </image>
                    </ImageView>
                    <Label text="I'm a" style="-fx-font-size: 14px; -fx-text-fill: #555555;" />
                    <Label text="Student" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #3E7C2B;" />
                  </children>
                </VBox>

                <VBox fx:id="teacherCard" onMouseClicked="#selectTeacher" accessibleText="I'm a teacher."
                      onMouseEntered="#speakAccessibleText"  onMouseExited="#cancelSpeak" alignment="CENTER"
                      spacing="15.0" prefWidth="250.0" minWidth="250" maxWidth="250"
                      prefHeight="300" minHeight="300" maxHeight="300"
                      style="-fx-background-color: #FFF2CC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                  <children>
                    <ImageView fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                      <image>
                        <Image url="@assets/images/teacher_chick.png" />
                      </image>
                    </ImageView>
                    <Label text="I'm a" style="-fx-font-size: 14px; -fx-text-fill: #555555;" />
                    <Label text="Teacher" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #D4A017;" />
                  </children>
                </VBox>

                <VBox fx:id="parentCard" onMouseClicked="#selectParent" accessibleText="I'm a Parent."
                      onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak" alignment="CENTER"
                      spacing="15.0" prefWidth="250.0" minWidth="250" maxWidth="250"
                      prefHeight="300" minHeight="300" maxHeight="300"
                      style="-fx-background-color: #F8CECC; -fx-background-radius: 20; -fx-padding: 25; -fx-cursor: hand;">
                  <children>
                    <ImageView fitHeight="150.0" fitWidth="150.0" pickOnBounds="true" preserveRatio="true">
                      <image>
                        <Image url="@assets/images/guardian_chick.png" />
                      </image>
                    </ImageView>
                    <Label text="I'm a" style="-fx-font-size: 14px; -fx-text-fill: #555555;" />
                    <Label text="Parent" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #B85450;" />
                  </children>
                </VBox>
              </children>
            </HBox>

            <Button fx:id="nextButton" text="Next" accessibleText="next" onMouseEntered="#speakAccessibleText"
                    onMouseExited="#cancelSpeak" prefHeight="50.0" prefWidth="350.0" onAction="#handleNext"
                    style="-fx-background-color: #6DBE45; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size:
                                18px; -fx-background-radius: 15; -fx-cursor: hand;" />
          </children>
        </VBox>
      </children>
    </VBox>

    <!-- 3. UI Overlay Layer (Tombol Back diletakkan paling akhir agar berada di paling depan) -->
    <AnchorPane pickOnBounds="false">
      <children>
        <Button onAction="#handleBack" layoutX="40.0" layoutY="40.0" prefHeight="45.0" prefWidth="45.0"
                accessibleText="back" onMouseEntered="#speakAccessibleText" onMouseExited="#cancelSpeak"
                style="-fx-background-color: #76C043; -fx-background-radius: 50; -fx-cursor: hand;">
          <graphic>
            <Label text="‹" mouseTransparent="true"
                   style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: bold; -fx-padding: 0 0 5 0;" />
          </graphic>
          <effect>
            <DropShadow color="#00000033" radius="5" offsetY="2" />
          </effect>
        </Button>
      </children>
    </AnchorPane>
  </children>
</StackPane>